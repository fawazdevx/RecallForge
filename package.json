{
  "name": "RecallForge",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm --prefix server run dev",
    "dev:all": "concurrently -n web,api -c magenta,cyan \"npm run dev\" \"npm run dev:server\"",
    "build:web": "tsc && vite build",
    "build:api": "esbuild server/src/index.ts --bundle --platform=node --format=esm --packages=external --outfile=api/index.js",
    "build": "npm run build:web && npm run build:api",
    "build:site": "npm run build:web && cp ws-resources.json dist/ws-resources.json",
    "preview": "vite preview",
    "codegen": "rm -rf src/contracts && sui-ts-codegen generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.68.0",
    "@mysten-incubation/memwal": "^0.0.7",
    "@mysten/dapp-kit-react": "^2.0.3",
    "@mysten/seal": "^1.1.3",
    "@mysten/sui": "^2.17.0",
    "@mysten/walrus": "^1.1.7",
    "@nanostores/react": "^1.0.0",
    "@tanstack/react-query": "^5.90.16",
    "ai": "^6.0.197",
    "clsx": "^2.1.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.4",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "lucide-react": "^0.562.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "tailwind-merge": "^3.4.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@mysten/codegen": "^0.10.6",
    "@tailwindcss/vite": "^4.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.23",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.2.2",
    "concurrently": "^9.1.2",
    "esbuild": "^0.24.2",
    "prettier": "^3.7.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^8.0.5"
  }
}
